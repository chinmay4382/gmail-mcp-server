{
  "mcpServers": {
    "email": {
      "command": "python3.12",
      "args": [
        "${MCP_SERVER_PATH}"
      ],
      "env": {
        "EMAIL_ADDRESS": "${EMAIL_ADDRESS}",
        "EMAIL_PASSWORD": "${EMAIL_PASSWORD}",
        "IMAP_SERVER": "${IMAP_SERVER}",
        "SMTP_SERVER": "${SMTP_SERVER}"
      }
    }
  }
}
